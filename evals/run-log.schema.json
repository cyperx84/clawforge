{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawforge.local/schemas/fleet-event.schema.json",
  "title": "ClawForge Fleet Event",
  "type": "object",
  "required": ["ts", "event", "agentId"],
  "properties": {
    "ts":        { "type": "string", "format": "date-time" },
    "event":     { "type": "string", "enum": ["created", "activated", "deactivated", "destroyed", "bound", "unbound", "cloned", "exported", "imported", "error"] },
    "agentId":   { "type": "string" },
    "agentName": { "type": "string" },
    "model":     { "type": "string" },
    "channel":   { "type": "string" },
    "notes":     { "type": "string" }
  }
}
